# python_cc/ is a thin wrapper — the scalar_udf package tree is copied from
# ../python/src/scalar_udf/ by the `build-scalar-udf-cc-python` Makefile
# target right before `uv build --sdist`. Nothing under src/ is committed so
# the CP (python/) and CC (python_cc/) source trees cannot drift apart.
src/

# uv / build output
.venv/
dist/
*.egg-info/
